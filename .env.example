# ============================================================
# TeslaMate Geocoder Configuration
# ============================================================

# PostgreSQL 连接（TeslaMate 数据库）
DATABASE_URL=postgres://user:password@host:5432/teslamate

# 地图服务 API Keys（至少配置一个）
TENCENT_MAP_KEY=
AMAP_KEY=
BAIDU_AK=

# Provider 优先级（逗号分隔，可选: tencent, amap, baidu）
PROVIDER_ORDER=tencent,amap,baidu

# Worker 配置
BATCH_SIZE=10
QPS_LIMIT=3
MAX_RETRIES=3
SCAN_INTERVAL_SECS=30

# 数据库连接池
DB_MAX_CONNECTIONS=5

# 监控
METRICS_ENABLED=true
METRICS_ADDR=127.0.0.1:9090

# 日志级别
RUST_LOG=teslamate_geocoder=info,sqlx=warn
